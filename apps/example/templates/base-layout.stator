<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>stator demo</title>
    <script is:inline>if (localStorage.getItem('stator-theme') === 'dark') { document.documentElement.dataset.theme = 'dark' }</script>
    <link rel="stylesheet" href="/static/app.css" />
  </head>
  <body>
    <children name="header"/>
    <main><children/></main>
    <!-- The Stator client runtime is auto-injected by the framework. -->
    <script src="/static/inspector.js" defer></script>
  </body>
</html>
